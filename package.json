{
  "name": "sanity-plugin-lamina",
  "version": "0.9.1",
  "description": "Sanity plugin for generating media assets with Lamina — Studio UI, headless API, CLI, and webhooks",
  "keywords": [
    "sanity",
    "sanity-plugin",
    "lamina",
    "ai",
    "media-generation",
    "image-generation",
    "video-generation",
    "asset-source",
    "headless",
    "cli",
    "content-pipeline",
    "webhook"
  ],
  "homepage": "https://docs.uselamina.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/uselamina/sanity-plugin-lamina.git"
  },
  "license": "MIT",
  "author": "Lamina <hello@uselamina.ai>",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sanity-lamina": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./headless": {
      "import": "./dist/headless/index.js",
      "types": "./dist/headless/index.d.ts"
    },
    "./webhooks": {
      "import": "./dist/webhooks/index.js",
      "types": "./dist/webhooks/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@sanity/client": "^6.29.1",
    "@uselamina/sdk": "^0.5.1",
    "react-is": "^19.2.5"
  },
  "devDependencies": {
    "@sanity/icons": "^3.5.0",
    "@sanity/ui": "^2.10.0",
    "react": "^19.0.0",
    "sanity": "^3.72.0",
    "styled-components": "^6.1.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@sanity/icons": "^3.0.0",
    "@sanity/ui": "^2.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "sanity": "^3.0.0",
    "styled-components": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@sanity/ui": {
      "optional": true
    },
    "@sanity/icons": {
      "optional": true
    },
    "styled-components": {
      "optional": true
    }
  }
}
